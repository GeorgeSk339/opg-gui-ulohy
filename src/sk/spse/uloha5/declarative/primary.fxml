<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.uloha5.declarative.Controller">
    <top>
        <Label text="Zoznam potravín" BorderPane.alignment="CENTER">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
            <BorderPane.margin>
                <Insets bottom="10.0" top="10.0" />
            </BorderPane.margin>
        </Label>
    </top>
    <center>
        <TableView fx:id="tabulka" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="id" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="nazovJedal" prefWidth="200.0" text="Názov" />
                <TableColumn fx:id="kalorie" prefWidth="100.0" text="Kalórie" />
                <TableColumn fx:id="cena" prefWidth="100.0" text="Cena" />
            </columns>
            <BorderPane.margin>
                <Insets left="15.0" right="15.0" />
            </BorderPane.margin>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" prefWidth="600.0" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#pridajPotravinu" text="Pridaj potravinu" />
                <Button mnemonicParsing="false" onAction="#vymaz" text="Vymaž" />
                <Button mnemonicParsing="false" onAction="#zatvor" text="Zatvor" />
            </children>
            <padding>
                <Insets right="15.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>