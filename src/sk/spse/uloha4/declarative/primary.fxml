<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.uloha4.declarative.Controller">
   <center>
      <TilePane alignment="CENTER" orientation="VERTICAL" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="vbox1" alignment="CENTER" prefHeight="200.0" prefWidth="120.0" style="-fx-background-color: blue;">
               <children>
                  <ImageView fx:id="img1" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@soup2.png" />
                     </image>
                  </ImageView>
               </children>
            </VBox>
            <VBox fx:id="vbox2" alignment="CENTER" prefHeight="200.0" prefWidth="120.0" style="-fx-background-color: yellow;">
               <children>
                  <ImageView fx:id="img2" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@soup2.png" />
                     </image>
                  </ImageView>
               </children>
            </VBox>
            <VBox fx:id="vbox3" alignment="CENTER" prefHeight="200.0" prefWidth="120.0" style="-fx-background-color: green;">
               <children>
                  <ImageView fx:id="img3" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@soup2.png" />
                     </image>
                  </ImageView>
               </children>
            </VBox>
            <VBox fx:id="vbox4" alignment="CENTER" prefHeight="200.0" prefWidth="120.0" style="-fx-background-color: red;">
               <children>
                  <ImageView fx:id="img4" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@soup2.png" />
                     </image>
                  </ImageView>
               </children>
            </VBox>
         </children>
      </TilePane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="200.0">
         <children>
            <VBox alignment="CENTER_LEFT">
               <children>
                  <Label text="&quot;In the future, everyone will be world-famous for 15 minutes&quot; " />
                  <Label text="- Andy Warhol" />
               </children>
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </HBox.margin>
            </VBox>
            <Label maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#randomize" text="Randomize">
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" top="10.0" />
               </HBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#close" text="Close">
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </bottom>
</BorderPane>